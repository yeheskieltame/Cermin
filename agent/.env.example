# Cermin keeper agent — copy to .env and fill PRIVATE_KEY.
MEZO_TESTNET_RPC=https://rpc.test.mezo.org

# Keeper signer (funds gas + triggers skim/defend). NEVER commit a real key.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Mezo matsnet v2 deployment.
CERMIN_FACTORY_ADDRESS=0x58C0adee08715EEaBc61d1de43C8a15ACaB45494
MEZO_PRICE_FEED_ADDRESS=0x86bCF0841622a5dAC14A313a15f96A95421b9366

# Optional — unused while hints are 0x0 (MVP). Safe to omit.
# MEZO_SORTED_TROVES_ADDRESS=

POLL_INTERVAL_MS=600000
DB_PATH=./data/cermin.db
LOG_LEVEL=info

# ── Keeper safety / health ──────────────────────────────────────────────────
# Warn when the signer's gas (BTC) balance drops below this many wei (1e15 =
# 0.001 BTC). Low gas means skim/defend silently fail — a missed defend can let
# a vault liquidate, so this surfaces it loudly.
GAS_WARN_THRESHOLD_WEI=1000000000000000
# Liveness server port. On Railway, PORT is injected and /health is probed
# automatically; locally the server listens on HEALTH_PORT.
HEALTH_PORT=8080
# A cycle running longer than this (ms) is treated as hung by the watchdog and
# reported unhealthy so the platform can restart a wedged process.
CYCLE_TIMEOUT_MS=300000

# ── Savings-yield simulation (testnet) ──────────────────────────────────────
# Mainnet: Mezo's PCV feeds the savings vault with real protocol fees.
# Testnet: the mock vault has no fee source, so the keeper drips a small,
# timestamp-proportional amount each window to mirror a ~5% APR. The PRIVATE_KEY
# signer must hold MUSD (e.g. the deployer wallet ~2k MUSD) + BTC for gas.
# Disabled by default — set YIELD_ENABLED=true to turn it on.
YIELD_ENABLED=false
YIELD_APR_BPS=500
MUSD_ADDRESS=0x118917a40FAF1CD7a13dB0Ef56C86De7973Ac503
SAVINGS_VAULT_ADDRESS=0xbcF023FF88ed5790a999AbE760dbD9d156c690a9
# Inject at most once per window; cap a single catch-up to avoid a big jump.
YIELD_MIN_INTERVAL_MS=3600000
YIELD_MAX_CATCHUP_MS=86400000
