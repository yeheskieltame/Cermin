# Cermin frontend environment

# WalletConnect / Reown project ID. Required for WalletConnect (mobile + QR)
# wallets. Get a free ID at https://cloud.reown.com.
# Without a real value, the MetaMask browser extension still connects, but
# WalletConnect-based wallets will fail at connect time.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional override for the Mezo Testnet RPC endpoint.
# Defaults to https://rpc.test.mezo.org when unset.
NEXT_PUBLIC_MEZO_RPC_URL=
